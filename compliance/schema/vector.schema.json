{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/postel-sh/postel/blob/main/compliance/schema/vector.schema.json",
  "title": "Postel Compliance Vector",
  "description": "Canonical schema for @postel/compliance test vectors. Vectors are authored as YAML files under compliance/vectors/<category>/<id>.yaml; the in-memory structure after parsing (YAML or JSON) is what this schema validates. The schema is itself a CONTRACT artifact governed by the compliance capability spec — every conformant runner agrees on this shape. Per the spec's `Vector file schema` requirement (openspec/specs/compliance/spec.md).",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "requirement", "description", "expected"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable test identifier of the form <category>/<vector-id> (e.g., 'signature-v1/tampered-body', 'sender/wire-output/hmac-v1-byte-stable').",
      "pattern": "^[a-z0-9][a-z0-9-]*(?:/[a-z0-9][a-z0-9-]*)+$"
    },
    "requirement": {
      "type": "object",
      "description": "The CONTRACT requirement this vector covers. Both fields verbatim-match a `### Requirement: <title>` block in openspec/specs/<capability>/spec.md.",
      "additionalProperties": false,
      "required": ["capability", "title"],
      "properties": {
        "capability": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "description": "Discriminator. 'receiver' (default when absent) = legacy v0.1 shape: the runner sends `input` to --target. 'sender' = the runner stands up a mock receiver, drives the sender via --sender-control, observes outgoing HTTP.",
      "enum": ["receiver", "sender"],
      "default": "receiver"
    },
    "input": {
      "type": "object",
      "description": "Receiver-mode: the HTTP request the runner sends to the target. REQUIRED when mode is 'receiver' or omitted; FORBIDDEN when mode is 'sender'.",
      "additionalProperties": false,
      "required": ["method", "url", "body_b64"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["POST", "PUT", "PATCH", "GET", "DELETE", "HEAD", "OPTIONS"]
        },
        "url": { "type": "string" },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "body_b64": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/]*={0,2}$"
        }
      }
    },
    "secrets": {
      "type": "array",
      "description": "References to test secret/key fixtures used by the vector. Required when signature_mode is 'computed'; optional otherwise.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "fixture"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "fixture": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*\\.ya?ml$" }
        }
      }
    },
    "signature_mode": {
      "type": "string",
      "description": "Receiver-mode only. 'static' or 'computed'.",
      "enum": ["static", "computed"]
    },
    "triggers": {
      "type": "array",
      "description": "Sender-mode only. Ordered control-plane operations the runner performs against the sender-under-test.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["op"],
        "properties": {
          "op": {
            "type": "string",
            "enum": ["register_endpoint", "send", "start_workers", "advance_clock", "wait_for"]
          },
          "as": { "type": "string" },
          "endpoint": { "type": "object" },
          "event": { "type": "object" },
          "concurrency": { "type": "integer", "minimum": 1 },
          "to": { "type": "string" },
          "ms": { "type": "integer", "minimum": 0 },
          "request_count": { "type": "integer", "minimum": 0 },
          "timeout_ms": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "mock_receiver": {
      "type": "object",
      "description": "Sender-mode only. Scripts the embedded mock receiver's responses to inbound deliveries from the sender.",
      "additionalProperties": false,
      "properties": {
        "default_response": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "type": "integer" },
            "headers": { "type": "object", "additionalProperties": { "type": "string" } },
            "body_b64": { "type": "string" },
            "delay_ms": { "type": "integer", "minimum": 0 }
          }
        },
        "scripted_responses": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["status"],
            "properties": {
              "status": { "type": "integer" },
              "headers": { "type": "object", "additionalProperties": { "type": "string" } },
              "body_b64": { "type": "string" },
              "delay_ms": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "expected_requests": {
      "type": "array",
      "description": "Sender-mode only. Length-exact list of outgoing HTTP requests the runner expects to observe at the mock receiver.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "endpoint": { "type": "string" },
          "method": { "type": "string", "default": "POST" },
          "path": { "type": "string" },
          "headers_match": { "type": "object", "additionalProperties": { "type": "string" } },
          "headers_present": { "type": "array", "items": { "type": "string" } },
          "headers_absent": { "type": "array", "items": { "type": "string" } },
          "body_b64": { "type": "string" },
          "body_json_equals": {},
          "signature_verifies": {
            "type": "object",
            "additionalProperties": false,
            "required": ["fixture_id"],
            "properties": {
              "fixture_id": { "type": "string" },
              "scheme": { "type": "string", "enum": ["v1", "v1a"] }
            }
          },
          "arrived_within_ms": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "after": { "type": "string" },
              "min_ms": { "type": "integer", "minimum": 0 },
              "max_ms": { "type": "integer", "minimum": 0 }
            }
          },
          "attempt_status": {
            "type": "string",
            "enum": [
              "pending",
              "success",
              "failed",
              "failed-permanent",
              "dead-letter",
              "expired",
              "filtered",
              "skipped",
              "ssrf-blocked"
            ]
          }
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome"],
      "properties": {
        "outcome": {
          "type": "string",
          "enum": ["accept", "reject", "duplicate"]
        },
        "error_code": {
          "type": "string",
          "enum": [
            "SIGNATURE_INVALID",
            "TIMESTAMP_TOO_OLD",
            "MALFORMED_HEADER",
            "UNKNOWN_KEY_ID",
            "RAW_BYTES_MISMATCH_DETECTED",
            "ENDPOINT_VALIDATION",
            "SSRF_BLOCKED",
            "ENDPOINT_DISABLED"
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "outcome": { "const": "accept" } } },
          "then": { "not": { "required": ["error_code"] } }
        },
        {
          "if": { "properties": { "outcome": { "const": "duplicate" } } },
          "then": { "not": { "required": ["error_code"] } }
        },
        {
          "if": { "properties": { "outcome": { "const": "reject" } } },
          "then": { "required": ["error_code"] }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "anyOf": [
          { "properties": { "mode": { "const": "receiver" } }, "required": ["mode"] },
          { "not": { "required": ["mode"] } }
        ]
      },
      "then": {
        "required": ["input", "signature_mode"]
      }
    },
    {
      "if": {
        "properties": { "mode": { "const": "sender" } },
        "required": ["mode"]
      },
      "then": {
        "required": ["triggers"]
      }
    },
    {
      "if": {
        "properties": { "signature_mode": { "const": "computed" } },
        "required": ["signature_mode"]
      },
      "then": {
        "properties": { "secrets": { "type": "array", "minItems": 1 } },
        "required": ["secrets"]
      }
    }
  ]
}
