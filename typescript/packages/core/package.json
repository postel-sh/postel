{
  "name": "@postel/core",
  "version": "0.0.0",
  "description": "Sender, receiver, types, and errors — the Postel TypeScript core.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/postel-sh/postel.git",
    "directory": "typescript/packages/core"
  },
  "homepage": "https://postel.dev",
  "bugs": "https://github.com/postel-sh/postel/issues",
  "keywords": [
    "webhooks",
    "standard-webhooks",
    "webhook",
    "hmac",
    "ed25519",
    "signature",
    "verify",
    "jwks",
    "postel"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "zod": "^3.24.0"
  }
}
