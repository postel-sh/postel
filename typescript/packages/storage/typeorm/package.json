{
  "name": "@postel/typeorm",
  "version": "0.0.0",
  "description": "Postel storage adapter — host hands Postel a TypeORM DataSource (Postgres, MySQL, or SQLite).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/postel-sh/postel.git",
    "directory": "typescript/packages/storage/typeorm"
  },
  "homepage": "https://postel.dev",
  "bugs": "https://github.com/postel-sh/postel/issues",
  "keywords": ["webhooks", "standard-webhooks", "typeorm", "storage", "postel"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --target es2022 --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "postel": {
    "adapter": {
      "category": "orm"
    }
  },
  "dependencies": {
    "@postel/core": "workspace:*",
    "@postel/storage-helpers": "workspace:*"
  },
  "peerDependencies": {
    "typeorm": ">=0.3.17"
  },
  "devDependencies": {
    "@postel/storage-testkit": "workspace:*",
    "@testcontainers/mysql": "10.13.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "20.17.10",
    "better-sqlite3": "12.10.0",
    "mysql2": "3.11.5",
    "reflect-metadata": "0.2.2",
    "typeorm": "0.3.20"
  }
}
