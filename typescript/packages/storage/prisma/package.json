{
  "name": "@postel/prisma",
  "version": "0.0.0",
  "description": "Postel storage adapter — host hands Postel a PrismaClient instance.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/postel-sh/postel.git",
    "directory": "typescript/packages/storage/prisma"
  },
  "homepage": "https://postel.dev",
  "bugs": "https://github.com/postel-sh/postel/issues",
  "keywords": ["webhooks", "standard-webhooks", "prisma", "storage", "postel"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "generate": "prisma generate",
    "build": "prisma generate && tsup src/index.ts --format esm,cjs --dts --sourcemap --target es2022 --clean",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "postel": {
    "adapter": {
      "category": "orm"
    }
  },
  "peerDependencies": {
    "@prisma/client": ">=6"
  },
  "dependencies": {
    "@postel/core": "workspace:*",
    "@postel/storage-helpers": "workspace:*"
  },
  "devDependencies": {
    "@postel/storage-testkit": "workspace:*",
    "@prisma/client": "^6.19.3",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "20.17.10",
    "better-sqlite3": "12.10.0",
    "prisma": "^6.19.3"
  }
}
