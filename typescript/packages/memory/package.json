{
  "name": "@postel/memory",
  "version": "0.0.0",
  "description": "In-memory Postel storage adapter — deterministic test backend and single-process demo backing.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "postel": {
    "adapter": {
      "category": "standalone"
    }
  },
  "dependencies": {
    "@postel/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "20.17.10"
  }
}
