{
  "name": "@postel/fastify",
  "version": "0.0.0",
  "description": "Fastify plugin and admin handlers for the Postel receiver.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --target es2022 --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@postel/admin": "workspace:*",
    "@postel/core": "workspace:*",
    "@postel/http": "workspace:*",
    "fastify-plugin": "4.5.1"
  },
  "peerDependencies": {
    "fastify": ">=4"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "fastify": "4.28.1"
  }
}
