{
  "name": "@postel/express",
  "private": true,
  "version": "0.0.0",
  "description": "Express middleware and admin handlers for the Postel receiver.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --target es2022 --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@postel/core": "workspace:*",
    "@postel/http": "workspace:*"
  },
  "peerDependencies": {
    "express": ">=4"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.17.10",
    "@types/supertest": "6.0.2",
    "express": "4.21.2",
    "supertest": "7.0.0"
  }
}
