{
  "name": "@postel/nestjs",
  "version": "0.0.0",
  "description": "NestJS module, guard, and decorators that gate a route with a configured Postel inbound source.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --target es2022 --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@postel/core": "workspace:*",
    "@postel/http": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10",
    "reflect-metadata": ">=0.1.13",
    "rxjs": ">=7"
  },
  "devDependencies": {
    "@nestjs/common": "10.4.15",
    "@types/node": "20.17.10",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  }
}
