{
  "name": "@postel/hono",
  "version": "0.0.0",
  "description": "Hono middleware and admin handlers for the Postel receiver.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/postel-sh/postel.git",
    "directory": "typescript/packages/frameworks/hono"
  },
  "homepage": "https://postel.dev",
  "bugs": "https://github.com/postel-sh/postel/issues",
  "keywords": ["webhooks", "standard-webhooks", "hono", "middleware", "receiver", "postel"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@postel/core": "workspace:*",
    "@postel/http": "workspace:*"
  },
  "peerDependencies": {
    "hono": ">=4"
  },
  "devDependencies": {
    "hono": "4.12.18"
  }
}
